# Brand config (public — baked into the client bundle at build time).
# Copy to .env or .env.local and adjust, or set in the deploy environment.

# Footer brand name (the linked text in the page footer).
VITE_BRAND_NAME=Membasuh

# Footer brand link href.
VITE_BRAND_URL=https://membasuh.com

# Site URL printed at the bottom of the Save-Image (1080x1920) story export.
VITE_SITE_URL=https://ihsg.membasuh.com
